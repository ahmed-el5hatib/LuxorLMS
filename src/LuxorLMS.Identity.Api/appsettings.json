{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "SecretKey": "ChangeThisToAStrongRandomSecretKeyAtLeast32CharactersLong!",
    "Issuer": "LuxorLMS",
    "Audience": "LuxorLMSUsers",
    "AccessTokenExpiryMinutes": "15",
    "RefreshTokenExpiryDays": "7"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=local_luxorlms.db"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "RateLimiting": {
    "Login": {
      "MaxRequests": 5,
      "WindowSeconds": 60
    },
    "Register": {
      "MaxRequests": 3,
      "WindowSeconds": 3600
    },
    "Refresh": {
      "MaxRequests": 10,
      "WindowSeconds": 60
    }
  }
}







