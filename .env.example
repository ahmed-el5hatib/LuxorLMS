# LuxorLMS Environment Variables Example
# Copy these values to Render Dashboard or use render.yaml

# Database
ConnectionStrings__DefaultConnection=Host=ep-winter-pine-au54at1x-pooler.c-10.us-east-1.aws.neon.tech; Database=LuxorLMS; Username=neondb_owner; Password=npg_F13aeQRVhJLq; SSL Mode=VerifyFull; Channel Binding=Require;

# JWT
Jwt__SecretKey=ChangeThisToAStrongRandomSecretKeyAtLeast32CharactersLong!
Jwt__Issuer=LuxorLMS
Jwt__Audience=LuxorLMSUsers
Jwt__AccessTokenExpiryMinutes=15
Jwt__RefreshTokenExpiryDays=7

# Redis (optional)
Redis__ConnectionString=localhost:6379

# Rate Limiting
RateLimiting__Login__MaxRequests=5
RateLimiting__Login__WindowSeconds=60
RateLimiting__Register__MaxRequests=3
RateLimiting__Register__WindowSeconds=3600
RateLimiting__Refresh__MaxRequests=10
RateLimiting__Refresh__WindowSeconds=60
